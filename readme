```mermaid
classDiagram
    class Main {
      +main(args: String[]): void
    }

    class GameManager {
      -game: Game
      +makeMove(player: Player): void
      +start(): void
      +getCurrentPlayer(): Player
      +isFinished(): boolean
      +getWinner(): Player
      +getEvents(): List~GameEvent~
      +getState(): GameState
    }

    class Game {
      -state: GameState
      -dice: Dice
      -ruleEngine: RuleEngine
      +makeMove(player: Player): void
      +play(): void
      +printEventLog(): void
      +getState(): GameState
    }

    class GameState {
      -board: Board
      -players: List~Player~
      -turnOrder: Deque~Player~
      -events: List~GameEvent~
      -winner: Player
      -finished: boolean
      +getBoard(): Board
      +getPlayers(): List~Player~
      +getCurrentPlayer(): Player
      +advanceTurn(): void
      +markWinner(winner: Player): void
      +getWinner(): Player
      +isFinished(): boolean
      +log(type: EventType, message: String): void
      +getEvents(): List~GameEvent~
    }

    class RuleEngine {
      -sixRule: Rule
      -movementRule: Rule
      -cellEffectRule: Rule
      +processTurn(state: GameState, player: Player, roll: int): TurnContext
    }

    class TurnContext {
      -player: Player
      -roll: int
      -startPosition: int
      -targetPosition: int
      -moveCancelled: boolean
      -extraTurn: boolean
      +getPlayer(): Player
      +getRoll(): int
      +getStartPosition(): int
      +getTargetPosition(): int
      +setTargetPosition(targetPosition: int): void
      +isMoveCancelled(): boolean
      +setMoveCancelled(moveCancelled: boolean): void
      +isExtraTurn(): boolean
      +setExtraTurn(extraTurn: boolean): void
    }

    class Board {
      -dimension: int
      -totalCells: int
      -cells: Map~int,Cell~
      -snakeByHead: Map~int,Snake~
      -ladderByStart: Map~int,Ladder~
      +getDimension(): int
      +getTotalCells(): int
      +getSize(): int
      +getCell(position: int): Cell
      +placeEffect(position: int, effect: CellEffect): void
      +getEffectAt(position: int): Optional~CellEffect~
      +placeSnake(snake: Snake): void
      +placeLadder(ladder: Ladder): void
      +getSnakeAt(position: int): Optional~Snake~
      +getLadderAt(position: int): Optional~Ladder~
    }

    class Cell {
      -number: int
      -effect: CellEffect
      -occupant: Player
      +getNumber(): int
      +getEffect(): Optional~CellEffect~
      +setEffect(effect: CellEffect): void
      +getOccupant(): Optional~Player~
      +isOccupied(): boolean
      +occupy(player: Player): void
      +vacate(): void
    }

    class Snake {
      -head: int
      -tail: int
      +getHead(): int
      +getTail(): int
    }

    class Ladder {
      -start: int
      -top: int
      +getStart(): int
      +getTop(): int
    }

    class Difficulty {
      <<enumeration>>
      EASY
      MEDIUM
      HARD
      +getSnakeCount(): int
      +getLadderCount(): int
      +fromLabel(label: String): Difficulty
    }

    class Player {
      <<interface>>
      +getName(): String
      +getPosition(): int
      +setPosition(position: int): void
      +getConsecutiveSixes(): int
      +incrementConsecutiveSixes(): void
      +resetConsecutiveSixes(): void
    }

    class PlayerImpl {
      -name: String
      -position: int
      -consecutiveSixes: int
    }

    class Dice {
      <<interface>>
      +roll(): int
    }

    class DiceImpl {
      -sides: int
      -random: Random
      +roll(): int
    }

    class CellEffect {
      <<interface>>
      +apply(player: Player): int
      +describe(): String
    }

    class SnakeEffect {
      -from: int
      -to: int
      +apply(player: Player): int
      +describe(): String
    }

    class LadderEffect {
      -from: int
      -to: int
      +apply(player: Player): int
      +describe(): String
    }

    class EventType {
      <<enumeration>>
      TURN_STARTED
      DICE_ROLLED
      MOVED
      EFFECT_APPLIED
      TURN_SKIPPED
      EXTRA_TURN
      WINNER_DECIDED
    }

    class GameEvent {
      -timestamp: LocalDateTime
      -type: EventType
      -message: String
      +getTimestamp(): LocalDateTime
      +getType(): EventType
      +getMessage(): String
    }

    class Rule {
      <<interface>>
      +apply(state: GameState, context: TurnContext): void
    }

    class InfiniteSixRule
    class LimitedSixRule
    class EasyMovementRule
    class HardMovementRule
    class CellEffectRule

    class RuleFactory {
      <<utility>>
      +createSixRule(limited: boolean): Rule
      +createMovementRule(hardBounceBack: boolean): Rule
      +createCellEffectRule(): Rule
    }

    class CellEffectFactory {
      <<utility>>
      +populateBoard(board: Board, difficulty: Difficulty): void
      +populateBoard(board: Board, difficulty: Difficulty, random: Random): void
    }

    class GameFactory {
      <<utility>>
      +createGame(n: int, playerCount: int, difficultyLabel: String): GameManager
      +createGame(n: int, playerCount: int, difficulty: Difficulty): GameManager
    }

    Main --> GameFactory
    Main --> GameManager

    GameManager *-- Game
    Game *-- GameState
    Game --> Dice
    Game ..> RuleEngine

    GameState *-- Board
    GameState o-- Player
    GameState o-- GameEvent

    Board *-- Cell
    Board o-- Snake
    Board o-- Ladder

    Cell --> CellEffect
    Cell --> Player

    Player <|.. PlayerImpl
    Dice <|.. DiceImpl
    CellEffect <|.. SnakeEffect
    CellEffect <|.. LadderEffect

    GameEvent --> EventType

    RuleEngine --> Rule
    RuleEngine *-- TurnContext

    Rule <|.. InfiniteSixRule
    Rule <|.. LimitedSixRule
    Rule <|.. EasyMovementRule
    Rule <|.. HardMovementRule
    Rule <|.. CellEffectRule

    CellEffectRule --> CellEffect
    RuleFactory ..> Rule

    CellEffectFactory ..> Board
    CellEffectFactory ..> Difficulty
    CellEffectFactory ..> Snake
    CellEffectFactory ..> Ladder

    GameFactory ..> Board
    GameFactory ..> Difficulty
    GameFactory ..> CellEffectFactory
    GameFactory ..> DiceImpl
    GameFactory ..> PlayerImpl
    GameFactory ..> GameState
    GameFactory ..> Game
    GameFactory ..> GameManager
```